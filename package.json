{
  "name": "usagemeter",
  "version": "0.1.0",
  "description": "A lightweight tray application for monitoring Claude Code usage",
  "author": "Smileslove",
  "license": "MIT",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/smileslove/UsageMeter"
  },
  "bugs": {
    "url": "https://github.com/smileslove/UsageMeter/issues"
  },
  "keywords": [
    "claude",
    "claude-code",
    "monitor",
    "tray",
    "usage",
    "token"
  ],
  "scripts": {
    "dev": "vite --port 1420",
    "dev:tauri": "tauri dev --config src-tauri/tauri.conf.dev.json",
    "build": "vue-tsc --noEmit && vite build",
    "build:tauri": "tauri build",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "ccusage": "18.0.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "echarts": "^6.0.0",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "shadcn-vue": "^2.5.3",
    "tailwind-merge": "^3.5.0",
    "vue": "^3.5.13",
    "vue-echarts": "^8.0.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10"
  }
}
