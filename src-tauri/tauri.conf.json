{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "UsageMeter",
  "version": "0.5.1",
  "identifier": "io.github.smileslove.usagemeter",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "UsageMeter",
        "width": 420,
        "height": 560,
        "backgroundColor": "#00000000",
        "visible": false,
        "transparent": true,
        "decorations": false,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE3NzlCRjM5MEY2QUE0OTQKUldTVXBHb1BPYjk1cCtrbjF5M1dUK1c2bHoxc3BiNE9WWVBtUmh2ZzhJQ25VSFNOdkt3V1JQTVYK",
      "endpoints": [
        "https://github.com/Smileslove/UsageMeter/releases/latest/download/latest.json"
      ],
      "dialog": false
    }
  }
}
